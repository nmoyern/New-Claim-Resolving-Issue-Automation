# Credentials — NEVER commit
.env
*.env
.env.*

# Sessions and cookies
sessions/
*.json.bak

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Data files (contain PHI/PII)
data/*.db
data/*.db-wal
data/*.db-shm
data/cache/
data/era_status.json
data/last_responseid.txt

# Per-run state files — regenerated every run, not code
data/posted_eras.json
data/availity_responses/

# Generated reports (live copies stay in Dropbox) — not code
docs/outstanding_claims_unified.xlsx
docs/powerbi_ar_report.xlsx
docs/fax_tracking_report.xlsx
docs/fax_tracking_report.txt

# Log files — may contain PHI and stack traces
logs/*.log

# Downloaded files
/tmp/
logs/screenshots/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Excel lock files
~$*.xlsx
~$*.xlsm
